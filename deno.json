{
  "license": "MPL-2.0",
  "links": [
    "libs/@types/gecko"
  ],
  "workspace": [
    "./libs/*",
    "./browser-features/*",
    "./bridge/*",
    "./i18n"
  ],
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.25",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/path": "jsr:@std/path@^1.1.4",
    "#i18n/": "./i18n/",
    "#chrome/": "./chrome/",
    "#libs/": "./libs/",
    "#features-chrome/": "./browser-features/chrome/",
    "#modules/": "./browser-features/modules/",
    "#ui/": "./src/ui/",
    "#themes/": "./src/themes/",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/streams": "jsr:@std/streams@^1.0.14",
    "@std/toml": "npm:@jsr/std__toml@^1.0.11",
    "vite": "npm:rolldown-vite@^7.3.0"
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "deno.window",
      "ESNext"
    ],
    "checkJs": true,
    "skipLibCheck": true
  },
  "exclude": [
    "tools/build/tasks/inject/wasm/nora-inject.js",
    "**/_dist/**/*",
    "**/*.timestamp-*.mjs",
    "libs/@types/gecko/**/*",
    "libs/vite-plugin-gen-jarmn/**/*",
    "libs/vite-plugin-disable-csp/**/*",
    "tools/build/tasks/inject/mixins/**/*",
    "browser-features/skin/lepton/userjs/**/*",
    "browser-features/modules/modules/os-server/_os-plugin/**/*",
    "browser-features/chrome/experiment/csk/**/*",
    "browser-features/chrome/common/reverse-sidebar-position/**/*",
    "bridge/loader-features/vite.config.ts",
    "bridge/loader-modules/tsdown.config.ts",
    "bridge/startup/tsdown.config.ts",
    "static/installers/**/*",
    "logs/**/*",
    "node_modules/**/*"
  ],
  "tasks": {
    "feles-build": "deno run -A tools/feles-build.ts",
    "act": "deno run -A tools/act/run-package-workflow.ts",
    "dev-tool": "deno run -A tools/dev-tool.ts",
    "docs-harness": "deno run --allow-read --allow-write --allow-env --allow-net --allow-run tools/docs-harness/mod.ts",
    "docs-harness:collect": "deno run --allow-read --allow-write=_dist --allow-run=git tools/docs-harness/mod.ts collect",
    "docs-harness:generate": "deno run --allow-read --allow-write=_dist,docs --allow-env=DOCS_LLM_BASE_URL,DOCS_LLM_MODEL,DOCS_LLM_API_KEY,DOCS_LLM_TEMPERATURE,DOCS_LLM_RESPONSE_FORMAT --allow-net tools/docs-harness/mod.ts generate",
    "docs-harness:generate-docs": "deno run --allow-read --allow-write=_dist,docs --allow-env=DOCS_LLM_BASE_URL,DOCS_LLM_MODEL,DOCS_LLM_API_KEY,DOCS_LLM_TEMPERATURE,DOCS_LLM_RESPONSE_FORMAT --allow-net tools/docs-harness/mod.ts generate --inventory _dist/docs-harness/inventory.json --out docs",
    "docs-harness:audit": "deno run --allow-read --allow-write=_dist --allow-env=DOCS_LLM_BASE_URL,DOCS_LLM_MODEL,DOCS_LLM_API_KEY,DOCS_LLM_TEMPERATURE,DOCS_LLM_RESPONSE_FORMAT,DOCS_AUDIT_LLM_BASE_URL,DOCS_AUDIT_LLM_MODEL,DOCS_AUDIT_LLM_API_KEY,DOCS_AUDIT_LLM_TEMPERATURE,DOCS_AUDIT_LLM_RESPONSE_FORMAT --allow-net tools/docs-harness/mod.ts audit",
    "docs-harness:audit-verify": "deno run --allow-read=_dist tools/docs-harness/mod.ts audit-verify",
    "docs-harness:codex-seed": "deno run --allow-read --allow-write=_dist,docs tools/docs-harness/mod.ts codex-seed",
    "docs-harness:codex-seed-docs": "deno run --allow-read --allow-write=_dist,docs tools/docs-harness/mod.ts codex-seed --inventory _dist/docs-harness/inventory.json --out docs --prompt-out _dist/docs-harness/codex/generate.md",
    "docs-harness:codex-audit-schema": "deno run --allow-read tools/docs-harness/mod.ts codex-audit-schema",
    "docs-harness:codex-audit-verify": "deno run --allow-read=_dist tools/docs-harness/mod.ts codex-audit-verify",
    "docs-harness:verify": "deno run --allow-read --allow-write=_dist tools/docs-harness/mod.ts verify",
    "docs-harness:verify-docs": "deno run --allow-read --allow-write=_dist tools/docs-harness/mod.ts verify --inventory _dist/docs-harness/inventory.json --docs-dir docs",
    "test": "deno run -A tools/src/colocated_test_runner.ts",
    "test:host": "deno test --allow-read --allow-write tools/src/",
    "test:docs-harness": "deno test --allow-read --allow-write --allow-net=127.0.0.1 tools/docs-harness/",
    "test:smoke": "deno run -A tools/src/smoke_runner.ts",
    "test:os-api": "deno run -A tools/os-test/verify_os_server_full.ts",
    "test:os-api:wrapper": "deno run -A tools/os-test/run_verify_os_server_full_wrapper.ts",
    "test:os-api:network-idle": "deno run -A tools/os-test/verify_network_idle_rigorous.ts",
    "test:os-api:local-page": "deno run -A tools/os-test/test-with-local-page.ts",
    "test:os-api:effects": "deno run -A tools/os-test/test-enhanced-effects.ts",
    "test:integration": "deno task test && deno task test:os-api --quick"
  },
  "nodeModulesDir": "manual"
}
